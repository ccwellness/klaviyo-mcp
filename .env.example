# .env.example — copy to .env and fill in real values.
#
# NEVER commit .env. This example file is safe to commit because it
# contains only placeholders, not real keys.
#
# The service reads .env at startup via python-dotenv. A real environment
# variable always wins over the .env file (override=False).
#
# Search order for .env (highest priority first):
#   Windows  : %APPDATA%\klaviyo-mcp\.env
#   macOS    : ~/Library/Application Support/klaviyo-mcp/.env
#   Linux    : ~/.config/klaviyo-mcp/.env
#   Fallback : <repo root>/.env

# ---------------------------------------------------------------------------
# Klaviyo API keys — one per account.
#
# Each account entry in accounts.toml has an "api_key_env" field naming the
# env var that holds its private API key.  Add one variable here for every
# account in your accounts.toml.
#
# Format:  KLAVIYO_<NAME>_KEY=pk_...
# The name must match what you put in api_key_env (case-sensitive).
#
# Example entries — replace with your real account names and keys:
# ---------------------------------------------------------------------------
KLAVIYO_ACME_KEY=pk_replace_with_real_acme_key
KLAVIYO_WIDGETS_KEY=pk_replace_with_real_widgets_key

# ---------------------------------------------------------------------------
# REST adapter credentials.
#
# Required when running the Flask REST adapter (at least one of REST_API_KEY or
# REST_API_TOKENS). Every request except GET /health must present a valid token,
# as either:   Authorization: Bearer <token>   or   X-API-Key: <token>
#
# REST_API_KEY is a single shared secret. REST_API_TOKENS is a comma-separated
# list of additional valid tokens, so you can issue one per client and rotate or
# revoke them individually (drop a token from the list to revoke it).
#
# Generate strong random values, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ---------------------------------------------------------------------------
REST_API_KEY=
REST_API_TOKENS=

# ---------------------------------------------------------------------------
# Optional overrides — leave blank to use the built-in defaults.
# ---------------------------------------------------------------------------

# Klaviyo base URL. Default: https://a.klaviyo.com
# Override only when routing through a proxy or test double.
KLAVIYO_BASE_URL=

# Pinned Klaviyo API revision header sent on every request. Default: 2025-04-15
# Bumping this is a deliberate, reviewed change — do not change it casually.
KLAVIYO_REVISION=

# Retry budget for 429/5xx responses from Klaviyo. Default: 3
KLAVIYO_MAX_RETRIES=

# Response-cache TTL in seconds. Default: 300 (5 min). Set to 0 to disable caching
# and always fetch fresh. Eases Klaviyo's report rate limits on repeated queries.
CACHE_TTL_SECONDS=

# Flask REST adapter bind address. Defaults: 127.0.0.1 / 8080
REST_HOST=
REST_PORT=

# Explicit path to accounts.toml. Leave blank to use the default search path.
# Default search order: user config dir → repo root.
ACCOUNTS_FILE=
